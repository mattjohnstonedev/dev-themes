@charset "UTF-8";
.nobrush, .frame-outer, .frame-inner {
	fill: none;
}

/*** pixmaps ***/

.breadcrumb .brush {
	fill: #f8f8f2;
}
.breadcrumb .pen {
	fill: none;
	stroke: #f8f8f2;
	stroke-width: 25.8739
}

.pixmap .brush {
	fill: #f8f8f2;
}
.pixmap .pen {
	fill: none;
	stroke: #f8f8f2;
	stroke-width: 25.8739;
}

.tabbar .brush {
	fill: #f8f8f2;
}

.tabbar .pen {
	fill: none;
	stroke: #f8f8f2;
	stroke-width: 25.8739
}

#filerPane      		.brush { fill: #8be9fd; }
#logo					.brush { fill: #ff5555; }
#monoLogo				.brush { fill: #f8f8f2; }
#outlinePane    		.brush { fill: #bd93f9; }
#outputPane     		.brush { fill: #50fa7b; }
#projectPane    		.brush { fill: #ff79c6; }
#senderPane     		.brush { fill: #bd93f9; }
#sessionPane    		.brush { fill: #8be9fd; }
#start          		.brush { fill: #50fa7b; }
#stop           		.brush { fill: #ff5555; }
#transferPane   		.brush { fill: #bd93f9; }

#colorDarkCyan			.brush { fill-opacity: 0.88; fill: #8be9fd; }
#colorDeepPink			.brush { fill-opacity: 0.88; fill: #ff79c6; }
#colorForestGreen		.brush { fill-opacity: 0.88; fill: #50fa7b; }
#colorGoldenrod			.brush { fill-opacity: 0.88; fill: #f1fa8c; }
#colorIndianRed			.brush { fill-opacity: 0.88; fill: #ff5555; }
#colorMediumOrchid		.brush { fill-opacity: 0.88; fill: #bd93f9; }
#colorMediumSlateBlue	.brush { fill-opacity: 0.88; fill: #6272a4; }
#colorOlive				.brush { fill-opacity: 0.88; fill: #50fa7b; }
#colorRed				.brush { fill-opacity: 0.88; fill: #ff5555; }
#colorRoyalBlue			.brush { fill-opacity: 0.88; fill: #8be9fd; }
#colorSteelBlue			.brush { fill-opacity: 0.88; fill: #6272a4; }
#colorTeal				.brush { fill-opacity: 0.88; fill: #50fa7b; }

/*** symbols ***/

.symbol {
	font-family: 'Roboto Mono';
	font-size: 255.212px;
	font-weight: normal;
	fill: white;
	stroke: white;
	stroke-width: 2.96615;
}

#a .frame-outer, #A .frame-inner { stroke: #ff5555; fill: #ff5555; }
#b .frame-outer, #B .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#c .frame-outer, #C .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#d .frame-outer, #D .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#e .frame-outer, #E .frame-inner { stroke: #8be9fd; fill: #8be9fd; }
#f .frame-outer, #F .frame-inner { stroke: #ff5555; fill: #ff5555; }
#g .frame-outer, #G .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#h .frame-outer, #H .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#i .frame-outer, #I .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#j .frame-outer, #J .frame-inner { stroke: #f1fa8c; fill: #f1fa8c; }
#k .frame-outer, #K .frame-inner { stroke: #8be9fd; fill: #8be9fd; }
#l .frame-outer, #L .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#m .frame-outer, #M .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#n .frame-outer, #N .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#o .frame-outer, #O .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#p .frame-outer, #P .frame-inner { stroke: #8be9fd; fill: #8be9fd; }
#q .frame-outer, #Q .frame-inner { stroke: #ff5555; fill: #ff5555; }
#r .frame-outer, #R .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#s .frame-outer, #S .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#t .frame-outer, #T .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#u .frame-outer, #U .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#v .frame-outer, #V .frame-inner { stroke: #8be9fd; fill: #8be9fd; }
#w .frame-outer, #W .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#x .frame-outer, #X .frame-inner { stroke: #ff5555; fill: #ff5555; }
#y .frame-outer, #Y .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#z .frame-outer, #Z .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#num0 .frame-outer, #Num0 .frame-inner { stroke: #ff5555; fill: #ff5555; }
#num1 .frame-outer, #Num1 .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#num2 .frame-outer, #Num2 .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#num3 .frame-outer, #Num3 .frame-inner { stroke: #f1fa8c; fill: #f1fa8c; }
#num4 .frame-outer, #Num4 .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#num5 .frame-outer, #Num5 .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#num6 .frame-outer, #Num6 .frame-inner { stroke: #ff79c6; fill: #ff79c6; }
#num7 .frame-outer, #Num7 .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#num8 .frame-outer, #Num8 .frame-inner { stroke: #ff5555; fill: #ff5555; }
#num9 .frame-outer, #Num9 .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#and .frame-outer,      #And .frame-inner      { stroke: #ffb86c; fill: #ffb86c; }
#angles .frame-outer,   #Angles .frame-inner   { stroke: #8be9fd; fill: #8be9fd; }
#asterisk .frame-outer, #Asterisk .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#at .frame-outer,       #At .frame-inner       { stroke: #ff79c6; fill: #ff79c6; }
#braces .frame-outer,   #Braces .frame-inner   { stroke: #ff5555; fill: #ff5555; }
#brackets .frame-outer, #Brackets .frame-inner { stroke: #50fa7b; fill: #50fa7b; }
#dollar .frame-outer,   #Dollar .frame-inner   { stroke: #f1fa8c; fill: #f1fa8c; }
#dot .frame-outer,      #Dot .frame-inner      { stroke: #bd93f9; fill: #bd93f9; }
#equal .frame-outer,    #Equal .frame-inner    { stroke: #ff5555; fill: #ff5555; }
#exclamation .frame-outer, #Exclamation .frame-inner { stroke: #ffb86c; fill: #ffb86c; }
#minus .frame-outer,    #Minus .frame-inner    { stroke: #8be9fd; fill: #8be9fd; }
#parenthesis .frame-outer, #Parenthesis .frame-inner { stroke: #bd93f9; fill: #bd93f9; }
#percent .frame-outer,  #Percent .frame-inner  { stroke: #ff79c6; fill: #ff79c6; }
#plus .frame-outer,     #Plus .frame-inner     { stroke: #f1fa8c; fill: #f1fa8c; }
#plus .frame-outer,     #Plus .frame-inner     { stroke: #6272a4; fill: #6272a4; }
#pound .frame-outer,    #Pound .frame-inner    { stroke: #8be9fd; fill: #8be9fd; }
#power .frame-outer,    #Power .frame-inner    { stroke: #bd93f9; fill: #bd93f9; }
#question .frame-outer, #Question .frame-inner { stroke: #8be9fd; fill: #8be9fd; }
#quotes .frame-outer,   #Quotes .frame-inner   { stroke: #ff5555; fill: #ff5555; }
#slash .frame-outer,    #Slash .frame-inner    { stroke: #6272a4; fill: #6272a4; }
#snippet .frame-outer,  #Snippet .frame-inner  { stroke: #ff79c6; fill: #ff79c6; }
#label .symbol,         #Label .symbol         { stroke: #8be9fd; fill: #8be9fd; }
